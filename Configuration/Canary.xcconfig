// Canary release channel configuration
// This is the bleeding-edge channel, built from main branch.

SBX_CHANNEL = canary
SBX_BUNDLE_ID_SUFFIX = .canary
INFOPLIST_KEY_CFBundleName = SBX UI Canary
INFOPLIST_KEY_CFBundleDisplayName = SBX UI Canary

INFOPLIST_KEY_ITSAppUsesNonExemptEncryption = NO

PRODUCT_BUNDLE_IDENTIFIER = dev.tetra2000.sbx-ui$(SBX_BUNDLE_ID_SUFFIX)
SWIFT_ACTIVE_COMPILATION_CONDITIONS = $(inherited) CANARY
